	<property name="ireport.zoom" value="3.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="no" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
     detail_barang_keluar.`no_keluar` AS detail_barang_keluar_no_keluar,
     detail_barang_keluar.`kode_barang` AS detail_barang_keluar_kode_barang,
     detail_barang_keluar.`jml_keluar` AS detail_barang_keluar_jml_keluar,
     detail_barang_keluar.`subtotal_keluar` AS detail_barang_keluar_subtotal_keluar,
     barang_keluar.`tgl_keluar` AS barang_keluar_tgl_keluar,
     barang_keluar.`total_keluar` AS barang_keluar_total_keluar,
     barang.`kode_barang` AS barang_kode_barang,
     barang.`nama_barang` AS barang_nama_barang,
     barang.`harga` AS barang_harga,
     barang.`satuan` AS barang_satuan
FROM
     `barang_keluar` barang_keluar INNER JOIN `detail_barang_keluar` detail_barang_keluar ON barang_keluar.`no_keluar` = detail_barang_keluar.`no_keluar`
     INNER JOIN `barang` barang ON detail_barang_keluar.`kode_barang` = barang.`kode_barang`
WHERE
     detail_barang_keluar.no_keluar=$P{no}]]>
	</queryString>
